/* ===== Profile Header ===== */
.profile-header {
  text-align: center;
  padding: 40rpx 0 24rpx;
}
.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), #6366F1);
  margin: 0 auto 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #fff;
  font-weight: 700;
}
.username {
  font-size: 34rpx;
  font-weight: 700;
  display: block;
}
.user-stats {
  font-size: 24rpx;
  color: var(--text-tertiary);
  display: block;
  margin-top: 6rpx;
}

/* ===== Pro Card ===== */
.pro-card {
  margin: 0 20rpx 16rpx;
  background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);
  border-radius: var(--radius);
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.pro-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.pro-icon {
  font-size: 44rpx;
}
.pro-texts {
  display: flex;
  flex-direction: column;
}
.pro-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}
.pro-desc {
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 4rpx;
}
.pro-badge {
  background: rgba(255,255,255,0.25);
  backdrop-filter: blur(6px);
  border: 1rpx solid rgba(255,255,255,0.3);
  padding: 10rpx 20rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
}
.pro-arrow {
  font-size: 28rpx;
}

/* ===== Menu ===== */
.menu-card {
  padding: 8rpx 24rpx;
}
.menu-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--border);
}
.menu-item:last-child {
  border-bottom: none;
}
.menu-item:active {
  opacity: 0.6;
}
.menu-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}
.menu-text {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
}
.menu-badge {
  background: var(--primary);
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 600;
}
.menu-arrow {
  color: var(--text-tertiary);
  font-size: 28rpx;
}

/* ===== App Info ===== */
.app-info {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-tertiary);
  padding: 24rpx 0 120rpx;
}

/* ===== Tab Bar ===== */
.tab-bar {
  display: flex;
  background: #fff;
  border-top: 1rpx solid var(--border);
  padding-bottom: env(safe-area-inset-bottom, 0);
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  height: 100rpx;
}
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  color: var(--text-tertiary);
  font-size: 20rpx;
}
.tab-item.active {
  color: var(--primary);
}
.tab-icon {
  font-size: 40rpx;
  line-height: 1.2;
}
.tab-label {
  font-size: 20rpx;
  font-weight: 500;
}
