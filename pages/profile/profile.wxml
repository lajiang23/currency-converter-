<view class="page-profile">
  <!-- ===== User Header ===== -->
  <view class="profile-header">
    <view class="avatar">💱</view>
    <text class="username">{{_.app_version}}</text>
    <text class="user-stats">{{lang === 'en' ? 'Real-time exchange rates for 32 currencies' : '实时汇率 · 32 种货币支持'}}</text>
  </view>

  <!-- ===== Pro Card ===== -->
  <view class="pro-card" bindtap="onProTap">
    <view class="pro-left">
      <text class="pro-icon">👑</text>
      <view class="pro-texts">
        <text class="pro-title">{{_.pro_title}}</text>
        <text class="pro-desc">{{_.pro_desc}}</text>
      </view>
    </view>
    <view class="pro-badge">
      <text>{{_.pro_price}}</text>
      <text class="pro-arrow">›</text>
    </view>
  </view>

  <!-- ===== Menu ===== -->
  <view class="card menu-card">
    <view class="menu-item" bindtap="onMenuTap" data-action="alerts">
      <view class="menu-icon" style="background:#E8F0FE;">
        <text>🔔</text>
      </view>
      <text class="menu-text">{{_.menu_alerts}}</text>
      <view class="menu-badge">2</view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onMenuTap" data-action="favorites">
      <view class="menu-icon" style="background:#FEF3C7;">
        <text>⭐</text>
      </view>
      <text class="menu-text">{{_.menu_favorites}}</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onMenuTap" data-action="history">
      <view class="menu-icon" style="background:#ECFDF5;">
        <text>📋</text>
      </view>
      <text class="menu-text">{{_.menu_history}}</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onMenuTap" data-action="export">
      <view class="menu-icon" style="background:#F3E8FF;">
        <text>📊</text>
      </view>
      <text class="menu-text">{{_.menu_export}}</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onMenuTap" data-action="knowledge">
      <view class="menu-icon" style="background:#FEE2E2;">
        <text>💡</text>
      </view>
      <text class="menu-text">{{_.menu_knowledge}}</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onMenuTap" data-action="settings">
      <view class="menu-icon" style="background:#F3F4F6;">
        <text>⚙️</text>
      </view>
      <text class="menu-text">{{_.menu_settings}}</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- ===== App Info ===== -->
  <view class="app-info">
    <text>{{_.app_version}}</text>
  </view>

  <!-- ===== Tab Bar ===== -->
  <view class="tab-bar">
    <view class="tab-item" data-tab="index" bindtap="onTabTap">
      <text class="tab-icon">🏠</text>
      <text class="tab-label">{{_.tab_home}}</text>
    </view>
    <view class="tab-item" data-tab="multicurrency" bindtap="onTabTap">
      <text class="tab-icon">💱</text>
      <text class="tab-label">{{_.tab_multicurrency}}</text>
    </view>
    <view class="tab-item" data-tab="chart" bindtap="onTabTap">
      <text class="tab-icon">📈</text>
      <text class="tab-label">{{_.tab_chart}}</text>
    </view>
    <view class="tab-item active" data-tab="profile" bindtap="onTabTap">
      <text class="tab-icon">👤</text>
      <text class="tab-label">{{_.tab_profile}}</text>
    </view>
  </view>
</view>
