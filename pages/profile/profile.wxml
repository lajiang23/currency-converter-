<view class="page-profile">
  <!-- ===== User Header ===== -->
  <view class="profile-header">
    <view class="avatar">M</view>
    <text class="username">小明</text>
    <text class="user-stats">已使用 23 天 · 换算 156 次</text>
  </view>

  <!-- ===== Pro Card ===== -->
  <view class="pro-card" bindtap="onProTap">
    <view class="pro-left">
      <text class="pro-icon">👑</text>
      <view class="pro-texts">
        <text class="pro-title">解锁 Pro 会员</text>
        <text class="pro-desc">去广告 · 无限预警 · 深度数据</text>
      </view>
    </view>
    <view class="pro-badge">
      <text>¥9.9/月</text>
      <text class="pro-arrow">›</text>
    </view>
  </view>

  <!-- ===== Menu ===== -->
  <view class="card menu-card">
    <view class="menu-item" bindtap="onMenuTap" data-action="alerts">
      <view class="menu-icon" style="background:#E8F0FE;">
        <text>🔔</text>
      </view>
      <text class="menu-text">汇率预警</text>
      <view class="menu-badge">2</view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onMenuTap" data-action="favorites">
      <view class="menu-icon" style="background:#FEF3C7;">
        <text>⭐</text>
      </view>
      <text class="menu-text">收藏货币</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onMenuTap" data-action="history">
      <view class="menu-icon" style="background:#ECFDF5;">
        <text>📋</text>
      </view>
      <text class="menu-text">历史记录</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onMenuTap" data-action="export">
      <view class="menu-icon" style="background:#F3E8FF;">
        <text>📊</text>
      </view>
      <text class="menu-text">数据导出</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onMenuTap" data-action="knowledge">
      <view class="menu-icon" style="background:#FEE2E2;">
        <text>💡</text>
      </view>
      <text class="menu-text">汇率知识</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onMenuTap" data-action="settings">
      <view class="menu-icon" style="background:#F3F4F6;">
        <text>⚙️</text>
      </view>
      <text class="menu-text">设置</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- ===== App Info ===== -->
  <view class="app-info">
    <text>汇率换算 v1.0.0</text>
  </view>

  <!-- ===== Tab Bar ===== -->
  <view class="tab-bar">
    <view class="tab-item" data-tab="index" bindtap="onTabTap">
      <text class="tab-icon">🏠</text>
      <text class="tab-label">首页</text>
    </view>
    <view class="tab-item" data-tab="multicurrency" bindtap="onTabTap">
      <text class="tab-icon">💱</text>
      <text class="tab-label">多币种</text>
    </view>
    <view class="tab-item" data-tab="chart" bindtap="onTabTap">
      <text class="tab-icon">📈</text>
      <text class="tab-label">走势</text>
    </view>
    <view class="tab-item active" data-tab="profile" bindtap="onTabTap">
      <text class="tab-icon">👤</text>
      <text class="tab-label">我的</text>
    </view>
  </view>
</view>
