.page-add {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg);
}
.page-add-inner {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.select-all-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx 12rpx;
}
.select-all-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}
.select-all-count {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.currency-list {
  flex: 1;
  padding: 0 0 120rpx;
}

.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--card);
  border-radius: 16rpx;
  padding: 20rpx 22rpx;
  margin: 0 16rpx 8rpx;
  box-shadow: 0 1rpx 6rpx rgba(0,0,0,0.03);
  border: 1rpx solid transparent;
  transition: all 0.15s;
}
.list-item:active {
  opacity: 0.7;
}
.list-item.checked {
  background: #E8F0FE;
  border-color: rgba(26,115,232,0.25);
}

.li-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
}
.li-flag,
.list-item .flag-fallback {
  width: 44rpx;
  height: 33rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}
.li-info {
  display: flex;
  flex-direction: column;
}
.li-code {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}
.li-name {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 2rpx;
}

.li-checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #fff;
  font-weight: 700;
  flex-shrink: 0;
  transition: all 0.2s;
}
.li-checkbox.on {
  background: var(--primary);
  border-color: var(--primary);
  box-shadow: 0 2rpx 8rpx rgba(26,115,232,0.3);
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 20rpx env(safe-area-inset-bottom, 30rpx);
  background: var(--card);
  border-top: 1rpx solid var(--border);
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.04);
}
.confirm-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #1A73E8 0%, #1557B0 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  padding: 0;
  box-shadow: 0 4rpx 16rpx rgba(26,115,232,0.25);
}
.confirm-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}
