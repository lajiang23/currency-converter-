.page-add {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg);
}

.currency-list {
  flex: 1;
  padding: 16rpx 20rpx;
  padding-bottom: 120rpx;
}

.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--card);
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 8rpx;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
  border: 1rpx solid transparent;
}
.list-item:active {
  opacity: 0.7;
}
.list-item.checked {
  background: #E8F0FE;
  border-color: #1A73E8;
}

.li-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.li-flag,
.list-item .flag-fallback {
  width: 44rpx;
  height: 33rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}
.li-info {
  display: flex;
  flex-direction: column;
}
.li-code {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}
.li-name {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 2rpx;
}

.li-checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #fff;
  font-weight: 700;
  flex-shrink: 0;
}
.li-checkbox.on {
  background: var(--primary);
  border-color: var(--primary);
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 20rpx env(safe-area-inset-bottom, 30rpx);
  background: var(--card);
  border-top: 1rpx solid var(--border);
}
.confirm-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: var(--primary);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  padding: 0;
}
.confirm-btn:active {
  opacity: 0.8;
}
