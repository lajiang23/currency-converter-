.page-index {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg);
}

/* ===== Base Currency Section ===== */
.base-section {
  margin: 16rpx 20rpx;
  background: var(--card);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.05);
  flex-shrink: 0;
}
.base-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.base-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}
.base-change {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 500;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}
.base-change:active {
  background: var(--primary-light);
}
.base-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.base-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
}
.base-flag {
  font-size: 44rpx;
  line-height: 1;
}
.base-info {
  display: flex;
  flex-direction: column;
}
.base-code {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
}
.base-name {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 2rpx;
}
.base-input-wrap {
  background: var(--bg);
  border-radius: 14rpx;
  padding: 8rpx 20rpx;
  min-width: 160rpx;
  text-align: center;
}
.base-input {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text);
  text-align: center;
  width: 140rpx;
  height: 50rpx;
  background: transparent;
}
.base-input::-webkit-input-placeholder {
  color: var(--text-tertiary);
}

/* ===== Conversion List ===== */
.conversion-list {
  flex: 1;
  padding: 0 20rpx;
  padding-bottom: 16rpx;
}
.conv-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--card);
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 8rpx;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
}
.conv-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
}
.conv-flag {
  font-size: 40rpx;
  line-height: 1;
}
.conv-info {
  display: flex;
  flex-direction: column;
}
.conv-code {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text);
}
.conv-name {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 2rpx;
}
.conv-amount {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text);
  letter-spacing: -1rpx;
}

/* ===== Add Button ===== */
.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 24rpx 0;
}
.add-btn:active {
  opacity: 0.6;
}
.add-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid var(--primary);
  color: var(--primary);
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}
.add-text {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 500;
}

/* ===== Update Time ===== */
.update-bar {
  text-align: center;
  font-size: 20rpx;
  color: var(--text-tertiary);
  padding: 8rpx 0 env(safe-area-inset-bottom, 16rpx);
  flex-shrink: 0;
  background: var(--bg);
}

/* ===== Currency Picker Modal ===== */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.4);
  z-index: 200;
}
.picker-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  z-index: 201;
  padding: 20rpx 0 env(safe-area-inset-bottom, 30rpx);
  max-height: 65vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.25s ease;
}
.picker-sheet.show {
  transform: translateY(0);
}
.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 28rpx 16rpx;
}
.picker-title {
  font-size: 30rpx;
  font-weight: 700;
}
.picker-close {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--text-secondary);
}
.picker-list {
  flex: 1;
  overflow-y: auto;
  padding: 0 28rpx;
}
.picker-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}
.picker-item:last-child {
  border-bottom: none;
}
.picker-item:active {
  opacity: 0.6;
}
.pi-flag {
  font-size: 40rpx;
}
.pi-info {
  flex: 1;
}
.pi-code {
  font-size: 28rpx;
  font-weight: 600;
  display: block;
}
.pi-name {
  font-size: 22rpx;
  color: var(--text-tertiary);
  display: block;
  margin-top: 2rpx;
}
.pi-check {
  color: var(--primary);
  font-size: 28rpx;
  font-weight: 700;
}
