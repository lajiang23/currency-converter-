.page-index {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #F0F5FF 0%, var(--bg) 180rpx);
}

/* ===== Base Currency Section ===== */
.base-section {
  margin: 12rpx 16rpx 8rpx;
  background: linear-gradient(135deg, #1A73E8 0%, #1557B0 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  flex-shrink: 0;
  position: relative;
  overflow: hidden;
}
.base-section::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.06);
}
.base-section::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -10%;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.04);
}
.base-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}
.base-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  font-weight: 500;
  letter-spacing: 1rpx;
}
.base-change {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  font-weight: 500;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  background: rgba(255,255,255,0.12);
}
.base-change:active {
  background: rgba(255,255,255,0.2);
}
.base-change-icon {
  font-size: 28rpx;
  line-height: 1;
}

.base-main {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  position: relative;
  z-index: 1;
}
.base-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
}
.base-flag,
.base-section .flag-fallback {
  width: 52rpx;
  height: 40rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}
.base-section .flag-fallback {
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  color: #fff;
  font-size: 22rpx;
}
.base-info {
  display: flex;
  flex-direction: column;
}
.base-code {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.2;
}
.base-name {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
  margin-top: 2rpx;
}

.base-input-wrap {
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(8px);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 16rpx;
  padding: 8rpx 18rpx;
  min-width: 160rpx;
}
.base-input-sym {
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
  font-weight: 500;
}
.base-input {
  font-size: 38rpx;
  font-weight: 700;
  color: #fff;
  text-align: right;
  width: 120rpx;
  height: 44rpx;
  padding: 0;
  background: transparent;
}
.base-input::-webkit-input-placeholder {
  color: rgba(255,255,255,0.3);
}

/* ===== Conversion List ===== */
.conversion-list {
  flex: 1;
  padding: 0 16rpx 8rpx;
}

.list-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 8rpx 12rpx;
}
.list-header-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
}
.list-header-count {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.conv-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--card);
  border-radius: 18rpx;
  padding: 20rpx 22rpx;
  margin-bottom: 8rpx;
  box-shadow: 0 1rpx 6rpx rgba(0,0,0,0.04);
  transition: transform 0.15s;
}
.conv-item:active {
  transform: scale(0.985);
  opacity: 0.9;
}

.conv-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex: 1;
  min-width: 0;
}
.conv-flag,
.conv-item .flag-fallback {
  width: 44rpx;
  height: 33rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}
.conv-info {
  min-width: 0;
}
.conv-info-top {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.conv-code {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
}
.conv-rate {
  font-size: 20rpx;
  color: var(--text-tertiary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 200rpx;
}
.conv-name {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 2rpx;
  display: block;
}

.conv-right {
  text-align: right;
  flex-shrink: 0;
  margin-left: 12rpx;
}
.conv-amount {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
  letter-spacing: -0.5rpx;
  display: block;
  line-height: 1.2;
}
.conv-change {
  display: inline-flex;
  align-items: center;
  gap: 3rpx;
  margin-top: 4rpx;
  padding: 2rpx 10rpx;
  border-radius: 12rpx;
  font-size: 18rpx;
  font-weight: 500;
}
.conv-change.up {
  background: var(--green-bg);
  color: #059669;
}
.conv-change.down {
  background: var(--red-bg);
  color: var(--red);
}
.change-arrow {
  font-size: 14rpx;
}
.change-pct {
  font-size: 18rpx;
}

/* ===== Add Button ===== */
.add-btn-wrap {
  padding: 16rpx 0 4rpx;
}
.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  border: 2rpx dashed var(--border);
  background: var(--card);
}
.add-btn:active {
  border-color: var(--primary);
  background: var(--primary-light);
}
.add-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: var(--primary);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}
.add-text {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 600;
}

/* ===== Empty State ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 20rpx;
}
.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}
.empty-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}
.empty-sub {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
}

/* ===== Update Time ===== */
.update-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 20rpx;
  color: var(--text-tertiary);
  padding: 8rpx 0 env(safe-area-inset-bottom, 16rpx);
  flex-shrink: 0;
  background: var(--bg);
}
.update-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--green);
  display: inline-block;
}

/* ===== Currency Picker Modal ===== */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.45);
  z-index: 200;
}
.picker-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--card);
  border-radius: 28rpx 28rpx 0 0;
  z-index: 201;
  padding: 24rpx 0 env(safe-area-inset-bottom, 30rpx);
  max-height: 72vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
}
.picker-sheet.show {
  transform: translateY(0);
}
.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 28rpx 16rpx;
  border-bottom: 1rpx solid var(--border);
}
.picker-title {
  font-size: 30rpx;
  font-weight: 700;
}
.picker-close {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.picker-current {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 28rpx;
  background: var(--primary-light);
  margin: 0 20rpx 12rpx;
  border-radius: 14rpx;
}
.pc-label {
  font-size: 22rpx;
  color: var(--primary);
  font-weight: 500;
  margin-right: 4rpx;
}
.pc-flag {
  width: 36rpx;
  height: 27rpx;
  border-radius: 3rpx;
  flex-shrink: 0;
}
.pc-code {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--primary);
}
.pc-name {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-left: auto;
}

.picker-list {
  flex: 1;
  overflow-y: auto;
  padding: 0 28rpx;
}
.picker-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--border);
  transition: opacity 0.1s;
}
.picker-item:last-child {
  border-bottom: none;
}
.picker-item:active {
  opacity: 0.5;
}
.pi-flag,
.picker-item .flag-fallback {
  width: 44rpx;
  height: 33rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}
.pi-info {
  flex: 1;
}
.pi-code {
  font-size: 28rpx;
  font-weight: 600;
  display: block;
}
.pi-name {
  font-size: 22rpx;
  color: var(--text-tertiary);
  display: block;
  margin-top: 2rpx;
}
.pi-check {
  color: var(--primary);
  font-size: 28rpx;
  font-weight: 700;
}
