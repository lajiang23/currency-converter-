/* ===== Chart Card ===== */
.chart-card {
  margin: 20rpx 20rpx 16rpx;
  background: var(--card);
  border-radius: var(--radius);
  padding: 24rpx;
  box-shadow: var(--shadow);
}

.chart-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.chart-pair {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.cp-flags {
  font-size: 32rpx;
}
.cp-name {
  font-size: 30rpx;
  font-weight: 700;
}

.chart-periods {
  display: flex;
  gap: 6rpx;
}
.cp-btn {
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  background: var(--bg);
  color: var(--text-secondary);
}
.cp-btn.active {
  background: var(--primary);
  color: #fff;
}
.cp-btn:active {
  opacity: 0.7;
}

.chart-current-price {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.cc-price {
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: -1rpx;
}
.cc-change {
  font-size: 26rpx;
  font-weight: 600;
}
.cc-change.up { color: #059669; }
.cc-change.down { color: var(--red); }

.chart-canvas {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
  background: #FAFBFC;
}

.chart-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-top: 16rpx;
}
.cs-item {
  text-align: center;
  padding: 16rpx 8rpx;
  background: var(--bg);
  border-radius: var(--radius-sm);
}
.cs-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
  display: block;
}
.cs-value {
  font-size: 28rpx;
  font-weight: 700;
  display: block;
  margin-top: 4rpx;
}
.cs-value.up { color: #059669; }
.cs-value.down { color: var(--red); }

/* ===== Technical Indicators ===== */
.tech-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}
.tech-item {
  padding: 16rpx 8rpx;
  background: var(--bg);
  border-radius: var(--radius-sm);
  text-align: center;
}
.tech-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
  display: block;
}
.tech-value {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
  display: block;
  margin-top: 4rpx;
}

/* ===== Tab Bar ===== */
.tab-bar {
  display: flex;
  background: #fff;
  border-top: 1rpx solid var(--border);
  padding-bottom: env(safe-area-inset-bottom, 0);
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  height: 100rpx;
}
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  color: var(--text-tertiary);
  font-size: 20rpx;
}
.tab-item.active {
  color: var(--primary);
}
.tab-icon {
  font-size: 40rpx;
  line-height: 1.2;
}
.tab-label {
  font-size: 20rpx;
  font-weight: 500;
}
