<view class="page-multi">
  <!-- ===== Header Amount ===== -->
  <view class="multi-header">
    <view class="mh-label">{{baseAmountLabel}}</view>
    <view class="mh-input-row">
      <text class="mh-symbol">{{baseSymbol}}</text>
      <input class="mh-input" type="digit" value="{{baseAmount}}" bindinput="onBaseAmountChange" />
    </view>
  </view>

  <!-- ===== Search ===== -->
  <view class="search-box">
    <text class="search-icon">🔍</text>
    <input class="search-input" placeholder="{{_.search_placeholder}}" bindinput="onSearch" />
  </view>

  <!-- ===== Currency List ===== -->
  <scroll-view class="multi-list" scroll-y>
    <view class="multi-item" wx:for="{{displayList}}" wx:key="code"
      wx:for-item="item">
      <image wx:if="{{item.flagUrl}}" class="mi-flag" src="{{item.flagUrl}}" mode="aspectFit" />
      <view wx:else class="mi-flag flag-fallback">{{item.code.charAt(0)}}</view>
      <view class="mi-info">
        <text class="mi-code">{{item.code}}</text>
        <text class="mi-name">{{item.name}}</text>
      </view>
      <view class="mi-right">
        <text class="mi-amount">{{item.formatted}}</text>
        <view class="mi-change {{item.changeUp ? 'up' : 'down'}}">
          <text>{{item.changeUp ? '▲' : '▼'}} {{item.changePct}}%</text>
        </view>
      </view>
    </view>

    <!-- Empty state -->
    <view class="empty-state" wx:if="{{displayList.length === 0}}">
      <text class="empty-icon">🔍</text>
      <text class="empty-text">{{_.no_results}}</text>
    </view>
  </scroll-view>

  <!-- ===== Tab Bar ===== -->
  <view class="tab-bar">
    <view class="tab-item" data-tab="index" bindtap="onTabTap">
      <text class="tab-icon">🏠</text>
      <text class="tab-label">{{_.tab_home}}</text>
    </view>
    <view class="tab-item active" data-tab="multicurrency" bindtap="onTabTap">
      <text class="tab-icon">💱</text>
      <text class="tab-label">{{_.tab_multicurrency}}</text>
    </view>
    <view class="tab-item" data-tab="chart" bindtap="onTabTap">
      <text class="tab-icon">📈</text>
      <text class="tab-label">{{_.tab_chart}}</text>
    </view>
    <view class="tab-item" data-tab="profile" bindtap="onTabTap">
      <text class="tab-icon">👤</text>
      <text class="tab-label">{{_.tab_profile}}</text>
    </view>
  </view>
</view>
