/* ===== Header ===== */
.multi-header {
  margin: 20rpx 20rpx 16rpx;
  background: var(--card);
  border-radius: var(--radius);
  padding: 24rpx 28rpx;
  box-shadow: var(--shadow);
  text-align: center;
}
.mh-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}
.mh-base {
  color: var(--primary);
  font-weight: 600;
}
.mh-input-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 8rpx;
}
.mh-symbol {
  font-size: 40rpx;
  font-weight: 300;
  color: var(--text);
}
.mh-input {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--text);
  text-align: center;
  width: 260rpx;
  height: 70rpx;
  background: transparent;
}
.mh-input::-webkit-input-placeholder {
  color: var(--text-tertiary);
}

/* ===== Search ===== */
.search-box {
  display: flex;
  align-items: center;
  margin: 0 20rpx 16rpx;
  background: var(--card);
  border-radius: var(--radius-sm);
  padding: 16rpx 24rpx;
  gap: 12rpx;
  box-shadow: var(--shadow);
  border: 1rpx solid var(--border);
}
.search-box:focus-within {
  border-color: var(--primary);
}
.search-icon {
  font-size: 28rpx;
}
.search-input {
  flex: 1;
  font-size: 26rpx;
  background: transparent;
}
.search-input::-webkit-input-placeholder {
  color: var(--text-tertiary);
}

/* ===== List ===== */
.multi-list {
  margin: 0 20rpx;
  padding-bottom: 120rpx;
}
.multi-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: var(--card);
  border-radius: var(--radius-sm);
  padding: 20rpx 24rpx;
  margin-bottom: 8rpx;
  box-shadow: var(--shadow);
}
.multi-item:active {
  opacity: 0.7;
}
.mi-flag,
.multi-list .flag-fallback {
  width: 44rpx;
  height: 33rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}
.mi-info {
  flex: 1;
}
.mi-code {
  font-size: 28rpx;
  font-weight: 600;
  display: block;
}
.mi-name {
  font-size: 22rpx;
  color: var(--text-tertiary);
  display: block;
  margin-top: 2rpx;
}
.mi-right {
  text-align: right;
}
.mi-amount {
  font-size: 30rpx;
  font-weight: 700;
  display: block;
}
.mi-change {
  font-size: 20rpx;
  margin-top: 4rpx;
  display: inline-block;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
}
.mi-change.up {
  background: var(--green-bg);
  color: #059669;
}
.mi-change.down {
  background: var(--red-bg);
  color: var(--red);
}

/* ===== Empty State ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}
.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}
.empty-text {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* ===== Tab Bar ===== */
.tab-bar {
  display: flex;
  background: #fff;
  border-top: 1rpx solid var(--border);
  padding-bottom: env(safe-area-inset-bottom, 0);
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  height: 100rpx;
}
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  color: var(--text-tertiary);
  font-size: 20rpx;
}
.tab-item.active {
  color: var(--primary);
}
.tab-icon {
  font-size: 40rpx;
  line-height: 1.2;
}
.tab-label {
  font-size: 20rpx;
  font-weight: 500;
}
