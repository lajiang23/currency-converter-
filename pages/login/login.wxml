<view class="page-login">
  <!-- ===== Decorative Background ===== -->
  <view class="login-bg">
    <view class="bg-circle bg-circle-1"></view>
    <view class="bg-circle bg-circle-2"></view>
    <view class="bg-circle bg-circle-3"></view>
  </view>

  <!-- ===== Hero Section ===== -->
  <view class="hero">
    <view class="hero-icon">💱</view>
    <text class="hero-title">汇率换算</text>
    <text class="hero-sub">实时汇率 · 多币种换算 · 走势图表</text>
  </view>

  <!-- ===== Login Buttons ===== -->
  <view class="login-section">
    <button class="btn-wechat" bindtap="onWechatLogin">
      <image class="wx-icon" src="/images/wechat-icon.png" mode="aspectFit" wx:if="{{false}}" />
      <text class="wx-icon-text">微信</text>
      <text class="btn-text">微信一键登录</text>
    </button>

    <view class="btn-mock" bindtap="onMockLogin">
      <text class="mock-text">快速体验</text>
    </view>

    <!-- ===== Agreement ===== -->
    <view class="agreement">
      <text class="agree-text">登录即表示同意</text>
      <text class="agree-link">《用户协议》</text>
      <text class="agree-text">和</text>
      <text class="agree-link">《隐私政策》</text>
    </view>
  </view>
</view>
