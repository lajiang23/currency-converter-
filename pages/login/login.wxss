.page-login {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(180deg, #F0F5FF 0%, #FFFFFF 40%);
  position: relative;
  overflow: hidden;
}

/* ===== Background Decorations ===== */
.login-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
}
.bg-circle {
  position: absolute;
  border-radius: 50%;
}
.bg-circle-1 {
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(26,115,232,0.08) 0%, transparent 70%);
  top: -200rpx;
  right: -150rpx;
}
.bg-circle-2 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(99,102,241,0.06) 0%, transparent 70%);
  bottom: 300rpx;
  left: -100rpx;
}
.bg-circle-3 {
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(52,211,153,0.05) 0%, transparent 70%);
  bottom: 100rpx;
  right: 50rpx;
}

/* ===== Hero Section ===== */
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
  padding-bottom: 80rpx;
  position: relative;
  z-index: 1;
}
.hero-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #1A73E8 0%, #1557B0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  box-shadow: 0 16rpx 48rpx rgba(26,115,232,0.3);
  margin-bottom: 32rpx;
}
.hero-title {
  font-size: 52rpx;
  font-weight: 800;
  color: #1A1A2E;
  letter-spacing: 2rpx;
}
.hero-sub {
  font-size: 26rpx;
  color: var(--text-tertiary);
  margin-top: 12rpx;
  letter-spacing: 1rpx;
}

/* ===== Login Section ===== */
.login-section {
  padding: 0 48rpx;
  position: relative;
  z-index: 1;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding-bottom: 100rpx;
}

/* ===== WeChat Login Button ===== */
.btn-wechat {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07C160 0%, #06AD56 100%);
  border-radius: 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(7,193,96,0.3);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  transition: opacity 0.15s;
}
.btn-wechat:active {
  opacity: 0.85;
}
.wx-icon-text {
  font-size: 36rpx;
  font-weight: 700;
}
.btn-text {
  font-size: 32rpx;
  font-weight: 600;
}

/* ===== Mock Login ===== */
.btn-mock {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 80rpx;
  margin-top: 20rpx;
  border-radius: 40rpx;
  background: transparent;
  border: 1rpx solid var(--border);
}
.btn-mock:active {
  background: var(--bg);
}
.mock-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
  font-weight: 500;
}

/* ===== Agreement ===== */
.agreement {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 36rpx;
  gap: 2rpx;
}
.agree-text {
  font-size: 22rpx;
  color: var(--text-tertiary);
}
.agree-link {
  font-size: 22rpx;
  color: var(--primary);
  font-weight: 500;
}
